*.coverage.xml
*.gcov
*.gcda
*.gcno

# ------------------------------------------
# Docker y Contenedores
# ------------------------------------------
.dockerignore
docker-compose.override.yml

# ------------------------------------------
# Secretos y Configuración Local
# ------------------------------------------
