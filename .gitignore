# ------------------------------------------
.vs/
*.user
*.suo
*.userosscache
*.sln.docstates
*.vssettings
.vsconfig
*.suo.tmp
*.VC.db
*.VC.opendb
UpgradeLog.htm
_UpgradeReport_Files/

# ------------------------------------------
# Archivos y Carpetas de Visual Studio Code (VSC)
# ------------------------------------------
.vscode/
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.code-workspace
.history/

# ------------------------------------------
# Archivos y Carpetas de JetBrains Rider / IntelliJ
# ------------------------------------------
.idea/
*.sln.iml
*.idea.DotSettings.user
*.DotSettings.user

# ------------------------------------------
# Gestión de Dependencias (NuGet & Node)
# ------------------------------------------
*.nupkg
**/packages/
!**/packages/repositories.config
.nuget/packages/
project.lock.json
project.fragment.lock.json
**/node_modules/
**/package-lock.json

