appsettings.Local.json
appsettings.local.json
secrets.json
.secrets/
**/secrets.json
**/appsettings.Local.json

# ------------------------------------------
# Configuración del Servidor Web Express (IIS Express)
# ------------------------------------------
IISExpress/
*.iisExpress-code-workspace
applicationhost.config
.iisexpress/

